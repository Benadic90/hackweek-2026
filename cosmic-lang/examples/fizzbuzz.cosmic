// FizzBuzz in CosmicScript
// prints numbers 1 to 30, but:
// - "Fizz" if divisible by 3
// - "Buzz" if divisible by 5
// - "FizzBuzz" if divisible by both

let i = 1;

while (i <= 30) {
  if (i % 15 == 0) {
    print("FizzBuzz");
  } else if (i % 3 == 0) {
    print("Fizz");
  } else if (i % 5 == 0) {
    print("Buzz");
  } else {
    print(i);
  }
  i = i + 1;
}
